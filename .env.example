# ═══════════════════════════════════════════════════════════════════
# Draftly — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ═══════════════════════════════════════════════════════════════════
#
# ── Vercel — image & video providers (set these in Project → Settings → Environment Variables)
#
#   Images (API-Easy):         API_EASY_API_KEY + API_EASY_BASE_URL → Nano Banana Pro / Nano Banana (3D Builder + other routes).
#   Images (2K/4K Nano):      GEMINI_API_KEY → native Gemini image for Nano Banana Pro where used.
#   Images & motion (fal):     FAL_KEY (or fal_key) → Seedream 4.5, LTX 2.3 Fast i2v, LTX 2.3 extend-video (Pro+), other fal lanes.
#   Video (3D Builder default): API_EASY_* → Veo 3.1 Fast on paid plans (Basic+).
#   Video (optional fal):      FAL_KEY → LTX 2.3 Fast image-to-video in the builder; extend uses the same key on Pro+.
#
#   Also required on Vercel:   All NEXT_PUBLIC_FIREBASE_* (client) + Firebase Admin (FIREBASE_* below),
#                              DODO_PAYMENTS_* for subscriptions, NEXT_PUBLIC_APP_URL / site URL as needed.
#
# ═══════════════════════════════════════════════════════════════════

# ── Firebase Client SDK (public — safe to expose) ────────────────
# Get from: Firebase Console → Project Settings → General → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
# For mobile sign-in (Safari, etc.): set to your app domain so auth redirects stay same-origin.
# Examples: draftly.space, localhost (for dev). Add domain to Firebase → Auth → Authorized domains.
NEXT_PUBLIC_APP_DOMAIN=
# Canonical site URL for Open Graph / metadata (e.g. https://draftly.space)
NEXT_PUBLIC_SITE_URL=
# Must match Firebase Console → Project settings → Storage bucket (often project-id.appspot.com or *.firebasestorage.app). Typos break uploads/CORS.
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
# Set true to skip 3D builder cloud uploads when Storage is not set up (localStorage still works).
NEXT_PUBLIC_DISABLE_3D_CLOUD_SAVE=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Firebase Admin SDK (server-only — NEVER expose to client) ────
# Get from: Firebase Console → Project Settings → Service accounts → Generate new private key
#
# Option A — piecemeal vars in .env.local (recommended on Vercel):
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY_ID=your_private_key_id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your_project_id.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your_client_id
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/...
#
# Option B — local JSON file only (gitignored). Save the downloaded key as firebase-adminsdk.local.json
# and add to .env.local: FIREBASE_ADMIN_SDK_JSON_PATH=firebase-adminsdk.local.json
# If set, this overrides Option A for Admin SDK initialization.
# FIREBASE_ADMIN_SDK_JSON_PATH=firebase-adminsdk.local.json
#
# 3D Builder: cloud save uploads site/frames/video via POST /api/3d-builder/save-project-assets (Admin SDK).
# Without Admin credentials, browser uploads to Storage hit CORS; server-side save avoids that.
#
# Cloud save checklist (Firebase Console — you configure these; env vars do not replace rules):
#   • Firestore: metadata at users/{uid}/3dProjects/{projectId} — rules must allow that subcollection.
#   • Storage: blobs at users/{uid}/3d-projects/{projectId}/ (site.html, frames.zip, video.mp4, uploads/) — Storage rules must allow that path.
#   • Same Firebase project everywhere: NEXT_PUBLIC_FIREBASE_PROJECT_ID, FIREBASE_PROJECT_ID, and NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET must match Console (avoid typos like draftly vs draflty).
#   • Client still needs NEXT_PUBLIC_* for sign-in; server needs Admin for save-project-assets.
#
# Never paste a real service_account JSON block into this file — .env.example is for git. Use Option A in
# .env.local or Option B pointing at a gitignored JSON file. If a real key was ever committed, rotate it in
# Google Cloud → IAM → Service Accounts → Keys.

# ── Business OS: integration secrets (server-only) ────────────────
# Long random string (24+ chars). Used to AES-256-GCM encrypt third-party API keys in Firestore.
# If unset, saving integrations returns 503 until configured.
# INTEGRATIONS_ENCRYPTION_SECRET=

# ── API-Easy (server-only) ───────────────────────────────────────
# Default Studio routing: most image/video models use API-Easy (same key as before).
# Get from: your API-Easy dashboard
API_EASY_API_KEY=your_api_easy_api_key
API_EASY_BASE_URL=https://api.apiyi.com/v1
API_EASY_IMAGE_MODEL=nano-banana-pro
API_EASY_VIDEO_MODEL=veo-3.1-fast
# Veo start request (chat/completions) can take >5 min; Node fetch defaults to 300s headers timeout without this.
# Code uses undici Agent + default 600000 ms unless you override:
# API_EASY_VIDEO_START_TIMEOUT_MS=600000

# LTX Video official API (server-only) — 3D Builder when user picks an LTX model in Models & Quality.
# Create a key: https://console.ltx.video
# Either name works (code checks both):
LTX_VIDEO_API_KEY=
LTXV_API_KEY=

# Backward-compatible aliases (optional)
# If you already use old variable names, the code still supports them:
APIYI_API_KEY=
APIYI_BASE_URL=
APIYI_IMAGE_MODEL=
APIYI_VIDEO_MODEL=

# Google Gemini (direct) — Studio: Nano Banana Pro at 2K/4K uses native image API (not API-Easy)
# GEMINI_API_KEY=

# ── Dodo Payments — Subscription billing (server-only) ───────────
# Get from: https://app.dodopayments.com → Developer → API / Webhooks
DODO_PAYMENTS_API_KEY=your_dodo_payments_api_key
DODO_PAYMENTS_WEBHOOK_KEY=your_dodo_webhook_signing_secret
DODO_PAYMENTS_ENVIRONMENT=live_mode

# ── fal.ai — Kling Image V3, Veo 3.1 FL, LTX, etc. (server-only) ─
# Vercel often uses FAL_KEY (case-sensitive on Linux). Aliases supported:
#   FAL_SELL_API_KEY (optional dedicated) → FAL_KEY → fal_key
# Get from: https://fal.ai/dashboard/keys
FAL_SELL_API_KEY=
FAL_KEY=
fal_key=your_fal_api_key

# ── 3D Builder — motion video provider (server-only) ─────────────
# Default motion in the UI is Veo 3.1 Fast via API-Easy on paid plans. Optional: LTX 2.3 Fast (fal) when user picks it (FAL_KEY).
# veo-api-easy = Veo 3.1 Fast via API-Easy (Basic+; first/last frames; 2K/4K still Premium+).
# fal-ltx-13b-distilled = TEST: fal LTX Video 13B Distilled text-to-video (~$0.04/clip on fal).
#   Does NOT send the hero image (API is text-only). Prompt uses site + background + motion text.
# Prefer choosing video in the 3D Builder UI (Models & Quality → Video). This env only applies
# when the client omits displayVideoModelId (legacy): forces LTX text-to-video for all users.
BUILDER_VIDEO_PROVIDER=veo-api-easy
# Optional LTX test tuning (480p | 720p, default 720p):
# BUILDER_LTX13B_RESOLUTION=720p
# BUILDER_LTX13B_NUM_FRAMES=121
# BUILDER_LTX13B_DETAIL_PASS=false
# Optional: HMAC secret for LTX async video poll tokens (defaults to fal_key if unset)
# BUILDER_FAL_POLL_SECRET=

# ── Admin API (server-only) ───────────────────────────────────────
# Required for /api/admin/list-subscribers (list Dodo-subscribed emails)
ADMIN_SECRET_KEY=your_admin_secret_key

# ── GitHub OAuth (for Integrations → Connect GitHub) ───────────────
# Create OAuth App: https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Scroll template frames (public URL, optional) ─────────────────
# If WebPs are NOT in git under public/draftly-templates/.../frames-webp/,
# set this to the HTTPS base URL of that folder (no trailing slash).
# CDN must send CORS headers so the canvas can draw images.
# NEXT_PUBLIC_SCROLL_FRAME_BASE_URL=https://your-cdn.example.com/frames-webp

# ── Optional: Local AI server ────────────────────────────────────
# Only needed for self-hosted local GPU inference.
# Start: cd local-server && python server.py
LOCAL_AI_URL=http://localhost:8000

# ── Mailgun (server-only / local scripts — test & transactional email) ──
# Dashboard: https://app.mailgun.com
# US API: https://api.mailgun.net (default). EU: MAILGUN_URL=https://api.eu.mailgun.net
#
# Production (e.g. draftly.space)
MAILGUN_API_KEY=your_mailgun_private_api_key
MAILGUN_DOMAIN=draftly.space
MAILGUN_URL=https://api.mailgun.net
#
# Sandbox (optional — keep alongside prod; use: npm run mailgun:test:sandbox)
MAILGUN_SANDBOX_API_KEY=your_mailgun_sandbox_private_api_key
MAILGUN_SANDBOX_DOMAIN=sandbox99361bd3bc414e229f409703f5763e39.mailgun.org
#
# Optional: scripts/send-mailgun-test.mjs
# MAILGUN_FROM="Draftly <hello@draftly.space>"
# MAILGUN_TEST_TO="Your Name <you@example.com>"

# ── Developer dashboard ────────────────────────────────────────────
# Allowlist is hardcoded in lib/developer-access.ts (DEVELOPER_DASHBOARD_ALLOWED_EMAILS).
# No env var — edit that file to add or change developer operators.
